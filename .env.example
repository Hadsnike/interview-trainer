# Authorization key из личного кабинета GigaChat (Basic, base64 от client_id:client_secret)
GIGACHAT_AUTH_KEY=
# GIGACHAT_API_PERS — физлица, GIGACHAT_API_B2B / CORP — для бизнеса
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
# сертификаты Минцифры часто не установлены — оставьте false для локальной разработки
GIGACHAT_VERIFY_SSL=false
